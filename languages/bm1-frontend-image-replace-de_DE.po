msgstr "Ausgewählte entfernen"

#: includes/class-log-list-table__premium_only.php:158
msgid "Clear log"
msgstr "Protokoll leeren"

#: includes/class-log-list-table__premium_only.php:162
msgid "Remove all log entries?"
msgstr "Alle Protokolleinträge entfernen?"

#: includes/class-replacer.php:68 includes/class-replacer.php:185
msgid "Unauthorized."
msgstr "Nicht autorisiert."

